---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Fast and Reliable Video Game Collections' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Myrient</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="stylesheet" href={`${base}styles/global.css`} />
  </head>
  <body>
    <header class="site-header">
      <pre class="logo" aria-hidden="true">{`
______  ___              _____            _____ 
___   |/  /____  ___________(_)_____________  /_
__  /|_/ /__  / / /_  ___/_  /_  _ \\_  __ \\  __/
_  /  / / _  /_/ /_  /   _  / /  __/  / / / /_  
/_/  /_/  _\\__, / /_/    /_/  \\___//_/ /_/\\__/  
          /____/`}
      </pre>
      <p class="tagline">Where sharing is a priority</p>
      <p class="notice">
        Myrient will shut down on 31 March 2026. Download any content you find important.
      </p>
      <p class="notice-links">
        More information can be found on our
        <a href="https://discord.gg/4kVP9AuQ24" target="_blank" rel="noopener noreferrer">Discord server</a>
        and <a href="https://t.me/s/myrient/107" target="_blank" rel="noopener noreferrer">Telegram channel</a>.
      </p>
      <nav class="main-nav">
        <a href={base}>Home</a>
        <a href={`${base}files/`}>Files</a>
        <a href={`${base}donate/`}>Donate</a>
        <a href={`${base}faq/`}>FAQ</a>
        <a href={`${base}contact/`}>Contact Us</a>
        <a href="https://discord.gg/4kVP9AuQ24" target="_blank" rel="noopener noreferrer">Discord</a>
        <a href="https://t.me/s/myrient/107" target="_blank" rel="noopener noreferrer">Telegram</a>
        <a href="https://erista.me/" target="_blank" rel="noopener noreferrer">Erista</a>
      </nav>
      <p class="donate-prompt">
        <a href={`${base}donate/`}>
          If you found Myrient useful, please support us with a donation!
        </a>
      </p>
    </header>
    <main class="main-content">
      <slot />
    </main>
    <footer class="site-footer">
      <p>Myrient is an <a href="https://erista.me/" target="_blank" rel="noopener noreferrer">Erista</a> service. <a href={`${base}non-affiliation-disclaimer/`}>Non-Affiliation Disclaimer</a> | <a href={`${base}dmca/`}>DMCA</a></p>
    </footer>
  </body>
</html>
